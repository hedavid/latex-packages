    \filldraw[,line width=\fpeval{\tkzbrickfigscale*0.8}mm] plot[smooth] coordinates {(-0.3,-0.3) (0.3,0.15) (0.3,0.05)} -- cycle ;
  \end{scope}
}

\newcommand\inttkzshapebrickfigeyebrowD[2][1]{%man scary eyebrow
  \begin{scope}[shift={(#2)},xscale=#1]
