%====lenghts
\newlength{\tablericonsDefaultTotalHeight}
\newlength{\tablericonsDefaultHeight}
\newlength{\tablericonsNormalHeight}
\newlength{\tablericonsDefaultDepth}
\AtBeginDocument{%
	\setlength{\tablericonsDefaultHeight}{\fontcharht\font`X}%
	\setlength{\tablericonsNormalHeight}{\fontcharht\font`X}%
	}

%====suppress warnings
\begingroup\expandafter\expandafter\expandafter\endgroup
\expandafter\ifx\csname pdfsuppresswarningpagegroup\endcsname\relax
\else
	\pdfsuppresswarningpagegroup=1\relax
\fi

%====macro for generating filled version
\newcommand{\defineTablerIconFilled}[2]{%
	\expandafter\newcommand\csname tablericonfilled #2\endcsname[1]{%
		\includegraphics[page=#1, ##1]{tablericons-filled-all.pdf}}%
}%

%====macro for generating outline version
\newcommand{\defineTablerIconOutline}[2]{%
	\expandafter\newcommand\csname tablericonoutline #2\endcsname[1]{%
		\includegraphics[page=#1, ##1]{tablericons-outline-all.pdf}}%
}%

%====int macros
\newcommand{\tablericonfilled}[2][height=\tablericonsDefaultHeight]{%
	\csname tablericonfilled #2\endcsname{#1}%
}%

\newcommand{\tablericonoutline}[2][height=\tablericonsDefaultHeight]{%
	\csname tablericonoutline #2\endcsname{#1}%
}%

%====main macro
\defKV[tablericon]{height=\def\tablericonheigth{#1},strut=\def\tablericonstrut{#1},dstrut=\def\tablericondstrut{#1}}

\setKVdefault[tablericon]{height=dauto,filled=false,strut={X},dstrut={qX}}

\NewDocumentCommand\tablericon{O{}D<>{}m}{%
	\restoreKV[tablericon]%
	\setKV[tablericon]{#1}%
	\ifthenelse{\equal{\tablericonheigth}{auto}}%
		{%
			\settoheight\tablericonsDefaultHeight{\hbox{\tablericonstrut}}%height of \tablericonstrut
			\ifboolKV[tablericon]{filled}
				{%
					\tablericonfilled[height=\tablericonsDefaultHeight,#2]{#3}%
				}%
				{%
					\tablericonoutline[height=\tablericonsDefaultHeight,#2]{#3}%
				}%
		}%
		{%
			\ifthenelse{\equal{\tablericonheigth}{dauto}}%
				{%
					\settototalheight\tablericonsDefaultTotalHeight{\hbox{\tablericondstrut}}%height of \tablericondstrut
					\settodepth\tablericonsDefaultDepth{\hbox{\tablericondstrut}}%depth of \tablericondstrut
					\ifboolKV[tablericon]{filled}
					{%
						\raisebox{-\tablericonsDefaultDepth}{%
							\tablericonfilled[height=\tablericonsDefaultTotalHeight,#2]{#3}%
						}%
					}%
					{%
						\raisebox{-\tablericonsDefaultDepth}{%
							\tablericonoutline[height=\tablericonsDefaultTotalHeight,#2]{#3}%
						}%
					}%
				}%
				{%
					\IfSubStr{\tablericonheigth}{/}%
						{%
							\StrCut*{\tablericonheigth}{/}{\tablericonmanualheight}{\tablericonmanualdepth}%
							\setlength\tablericonsNormalHeight{\tablericonmanualheight}%
							\setlength\tablericonsDefaultDepth{\tablericonmanualdepth}%
							\ifboolKV[tablericon]{filled}%
								{%
									\raisebox{\tablericonsDefaultDepth}{%
										\tablericonfilled[height=\tablericonsNormalHeight,#2]{#3}%
									}%
								}%
								{%
									\raisebox{\tablericonsDefaultDepth}{%
										\tablericonoutline[height=\tablericonsNormalHeight,#2]{#3}%
									}%
								}%
						}%
						{%
							\setlength\tablericonsNormalHeight{\tablericonheigth}%
							\ifboolKV[tablericon]{filled}%
								{%
									\tablericonfilled[height=\tablericonsNormalHeight,#2]{#3}%
								}%
								{%
									\tablericonoutline[height=\tablericonsNormalHeight,#2]{#3}%
								}%
						}%
				}%
		}%
}

