%====lenghts
\newlength{\openmojiDefaultTotalHeight}
\newlength{\openmojiDefaultHeight}
\newlength{\openmojiNormalHeight}
\newlength{\openmojiDefaultDepth}
\AtBeginDocument{%
	\setlength{\openmojiDefaultHeight}{\fontcharht\font`X}%
	\setlength{\openmojiNormalHeight}{\fontcharht\font`X}%
	}

%====suppress warnings
\begingroup\expandafter\expandafter\expandafter\endgroup
\expandafter\ifx\csname pdfsuppresswarningpagegroup\endcsname\relax
\else
	\pdfsuppresswarningpagegroup=1\relax
\fi

%====macro for generating filled version
\newcommand{\defineOpenmojiColor}[2]{%
	\expandafter\newcommand\csname openmojicolor #2\endcsname[1]{%
		\includegraphics[page=#1, ##1]{openmoji-color-all.pdf}}%
}%

%====macro for generating outline version
\newcommand{\defineOpenmojiBlack}[2]{%
	\expandafter\newcommand\csname openmojiblack #2\endcsname[1]{%
		\includegraphics[page=#1, ##1]{openmoji-black-all.pdf}}%
}%

%====int macros
\newcommand{\openmojicolor}[2][height=\openmojiDefaultHeight]{%
	\csname openmojicolor #2\endcsname{#1}%
}%

\newcommand{\openmojiblack}[2][height=\openmojiDefaultHeight]{%
	\csname openmojiblack #2\endcsname{#1}%
}%

%====main macro
\defKV[openmoji]{height=\def\openmojiheigth{#1},strut=\def\openmojistrut{#1},dstrut=\def\openmojidstrut{#1}}

\setKVdefault[openmoji]{height=dauto,black=false,strut={X},dstrut={qX}}

\NewDocumentCommand\openmoji{O{}D<>{}m}{%
	\restoreKV[openmoji]%
	\setKV[openmoji]{#1}%
	\ifthenelse{\equal{\openmojiheigth}{auto}}%
		{%
			\settoheight\openmojiDefaultHeight{\hbox{\openmojistrut}}%height of \openmojistrut
			\ifboolKV[openmoji]{black}
				{%
					\openmojiblack[height=\openmojiDefaultHeight,#2]{#3}%
				}%
				{%
					\openmojicolor[height=\openmojiDefaultHeight,#2]{#3}%
				}%
		}%
		{%
			\ifthenelse{\equal{\openmojiheigth}{dauto}}%
				{%
					\settototalheight\openmojiDefaultTotalHeight{\hbox{\openmojidstrut}}%height of \openmojidstrut
					\settodepth\openmojiDefaultDepth{\hbox{\openmojidstrut}}%depth of \openmojidstrut
					\ifboolKV[openmoji]{black}
					{%
						\raisebox{-\openmojiDefaultDepth}{%
							\openmojiblack[height=\openmojiDefaultTotalHeight,#2]{#3}%
						}%
					}%
					{%
						\raisebox{-\openmojiDefaultDepth}{%
							\openmojicolor[height=\openmojiDefaultTotalHeight,#2]{#3}%
						}%
					}%
				}%
				{%
					\IfSubStr{\openmojiheigth}{/}%
						{%
							\StrCut*{\openmojiheigth}{/}{\openmojimanualheight}{\openmojimanualdepth}%
							\setlength\openmojiNormalHeight{\openmojimanualheight}%
							\setlength\openmojiDefaultDepth{\openmojimanualdepth}%
							\ifboolKV[openmoji]{black}%
								{%
									\raisebox{\openmojiDefaultDepth}{%
										\openmojiblack[height=\openmojiNormalHeight,#2]{#3}%
									}%
								}%
								{%
									\raisebox{\openmojiDefaultDepth}{%
										\openmojicolor[height=\openmojiNormalHeight,#2]{#3}%
									}%
								}%
						}%
						{%
							\setlength\openmojiNormalHeight{\openmojiheigth}%
							\ifboolKV[openmoji]{black}%
								{%
									\openmojiblack[height=\openmojiNormalHeight,#2]{#3}%
								}%
								{%
									\openmojicolor[height=\openmojiNormalHeight,#2]{#3}%
								}%
						}%
				}%
		}%
}

