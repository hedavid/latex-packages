%====lenghts
\newlength{\lucideiconDefaultTotalHeight}
\newlength{\lucideiconDefaultHeight}
\newlength{\lucideiconNormalHeight}
\newlength{\lucideiconDefaultDepth}
\AtBeginDocument{%
	\setlength{\lucideiconDefaultHeight}{\fontcharht\font`X}%
	\setlength{\lucideiconNormalHeight}{\fontcharht\font`X}%
	}

%====suppress warnings
\begingroup\expandafter\expandafter\expandafter\endgroup
\expandafter\ifx\csname pdfsuppresswarningpagegroup\endcsname\relax
\else
	\pdfsuppresswarningpagegroup=1\relax
\fi

%====macro for generating
\newcommand{\GenerateLucideIcons}[2]{%
	\expandafter\newcommand\csname lucideiconint #2\endcsname[1]{%
		\includegraphics[page=#1, ##1]{lucide-icons-all.pdf}}%
}%

%====int macros
\newcommand{\lucideiconint}[2][height=\lucideiconDefaultTotalHeight]{%
	\csname lucideiconint #2\endcsname{#1}%
}%

%====main macro
\defKV[lucideicon]{height=\def\lucideiconheigth{#1},strut=\def\lucideiconstrut{#1},dstrut=\def\lucideicondstrut{#1}}

\setKVdefault[lucideicon]{height=dauto,strut={X},dstrut={qX}}

\NewDocumentCommand\lucideicon{O{}D<>{}m}{%
	\restoreKV[lucideicon]%
	\setKV[lucideicon]{#1}%
	\ifthenelse{\equal{\lucideiconheigth}{auto}}%
		{%
			\settoheight\lucideiconDefaultHeight{\hbox{\lucideiconstrut}}%height of \lucideiconstrut
			\lucideiconint[height=\lucideiconDefaultHeight,#2]{#3}%
		}%
		{%
			\ifthenelse{\equal{\lucideiconheigth}{dauto}}%
				{%
					\settototalheight\lucideiconDefaultTotalHeight{\hbox{\lucideicondstrut}}%height of \lucideicondstrut
					\settodepth\lucideiconDefaultDepth{\hbox{\lucideicondstrut}}%depth of \lucideicondstrut
					\raisebox{-\lucideiconDefaultDepth}{%
						\lucideiconint[height=\lucideiconDefaultTotalHeight,#2]{#3}%
						}%
				}%
				{%
					\IfSubStr{\lucideiconheigth}{/}%
						{%
							\StrCut*{\lucideiconheigth}{/}{\lucideiconmanualheight}{\lucideiconmanualdepth}%
							\setlength\lucideiconNormalHeight{\lucideiconmanualheight}%
							\setlength\lucideiconDefaultDepth{\lucideiconmanualdepth}%
							\raisebox{\lucideiconDefaultDepth}{%
									\lucideiconint[height=\lucideiconNormalHeight,#2]{#3}%
								}%
						}%
						{%
							\setlength\lucideiconNormalHeight{\lucideiconheigth}%
							\lucideiconint[height=\lucideiconNormalHeight,#2]{#3}%
						}%
				}%
		}%
}

