%====main macro
\defKV[customenvsicons]{height=\def\customenvsiconsheigth{#1},style=\def\customenvsiconsstyle{#1},strut=\def\customenvsiconsstrut{#1},dstrut=\def\customenvsiconsdstrut{#1}}
\setKVdefault[customenvsicons]{height=dauto,educ=true,design=false,mathsymb=false,game=false,bootstrap=false,solar=false,themes=false,strut={X},dstrut={qX}}

\NewDocumentCommand\ceicon{O{}D<>{}m}{%
	\restoreKV[customenvsicons]%
	\setKV[customenvsicons]{#1}%
	\ifboolKV[customenvsicons]{design}{\setKV[customenvsicons]{educ=false}}{}%
	\ifboolKV[customenvsicons]{mathsymb}{\setKV[customenvsicons]{educ=false}}{}%
	\ifboolKV[customenvsicons]{game}{\setKV[customenvsicons]{educ=false}}{}%
	\ifboolKV[customenvsicons]{bootstrap}{\setKV[customenvsicons]{educ=false}}{}%
	\ifboolKV[customenvsicons]{solar}{\setKV[customenvsicons]{educ=false}}{}%
	%lengths
	\ifthenelse{\equal{\customenvsiconsheigth}{auto}}%
	{%
		\settoheight\customenvsIconsDefaultHeight{\hbox{\customenvsiconsstrut}}%height of \customenvsiconsstrut
		\ifboolKV[customenvsicons]{educ}{\ceiconeduc[height=\customenvsIconsDefaultHeight,#2]{#3}}{}%
		\ifboolKV[customenvsicons]{design}{\ceicondesign[height=\customenvsIconsDefaultHeight,#2]{#3}}{}%
		\ifboolKV[customenvsicons]{mathsymb}{\ceiconmathsymb[height=\customenvsIconsDefaultHeight,#2]{#3}}{}%
		\ifboolKV[customenvsicons]{game}{\ceicongame[height=\customenvsIconsDefaultHeight,#2]{#3}}{}%
		\ifboolKV[customenvsicons]{bootstrap}{\ceiconbootstrap[height=\customenvsIconsDefaultHeight,#2]{#3}}{}%
		\ifboolKV[customenvsicons]{solar}{\ceiconssolarbroken[height=\customenvsIconsDefaultHeight,#2]{#3}}{}%
	}%
	{%
		\ifthenelse{\equal{\customenvsiconsheigth}{dauto}}%
			{%
				\settototalheight\customenvsIconsDefaultTotalHeight{\hbox{\customenvsiconsdstrut}}%height of \customenvsiconsdstrut
				\settodepth\customenvsIconsDefaultDepth{\hbox{\customenvsiconsdstrut}}%depth of \customenvsiconsdstrut
				\ifboolKV[customenvsicons]{educ}{\raisebox{-\customenvsIconsDefaultDepth}{\ceiconeduc[height=\customenvsIconsDefaultTotalHeight,#2]{#3}}}{}%
				\ifboolKV[customenvsicons]{design}{\raisebox{-\customenvsIconsDefaultDepth}{\ceicondesign[height=\customenvsIconsDefaultTotalHeight,#2]{#3}}}{}%
				\ifboolKV[customenvsicons]{mathsymb}{\raisebox{-\customenvsIconsDefaultDepth}{\ceiconmathsymb[height=\customenvsIconsDefaultTotalHeight,#2]{#3}}}{}%
				\ifboolKV[customenvsicons]{game}{\raisebox{-\customenvsIconsDefaultDepth}{\ceicongame[height=\customenvsIconsDefaultTotalHeight,#2]{#3}}}{}%
				\ifboolKV[customenvsicons]{bootstrap}{\raisebox{-\customenvsIconsDefaultDepth}{\ceiconbootstrap[height=\customenvsIconsDefaultTotalHeight,#2]{#3}}}{}%
				\ifboolKV[customenvsicons]{solar}{\raisebox{-\customenvsIconsDefaultDepth}{\ceiconssolarbroken[height=\customenvsIconsDefaultTotalHeight,#2]{#3}}}{}%
			}%
			{%
				\IfSubStr{\customenvsiconsheigth}{/}%
					{%
						\StrCut{\customenvsiconsheigth}{/}{\ceiconsmanualheight}{\ceiconsmanualdepth}%
						\setlength\customenvsIconsNormalHeight{\ceiconsmanualheight}%
						\setlength\customenvsIconsDefaultDepth{\ceiconsmanualdepth}%
						\ifboolKV[customenvsicons]{educ}{\raisebox{\customenvsIconsDefaultDepth}{\ceiconeduc[height=\customenvsIconsNormalHeight,#2]{#3}}}{}%
						\ifboolKV[customenvsicons]{design}{\raisebox{\customenvsIconsDefaultDepth}{\ceicondesign[height=\customenvsIconsNormalHeight,#2]{#3}}}{}%
						\ifboolKV[customenvsicons]{mathsymb}{\raisebox{\customenvsIconsDefaultDepth}{\ceiconmathsymb[height=\customenvsIconsNormalHeight,#2]{#3}}}{}%
						\ifboolKV[customenvsicons]{game}{\raisebox{\customenvsIconsDefaultDepth}{\ceicongame[height=\customenvsIconsNormalHeight,#2]{#3}}}{}%
						\ifboolKV[customenvsicons]{bootstrap}{\raisebox{-\customenvsIconsDefaultDepth}{\ceiconbootstrap[height=\customenvsIconsDefaultTotalHeight,#2]{#3}}}{}%
						\ifboolKV[customenvsicons]{solar}{\raisebox{-\customenvsIconsDefaultDepth}{\ceiconssolarbroken[height=\customenvsIconsDefaultTotalHeight,#2]{#3}}}{}%
					}%
					{%
						\setlength\customenvsIconsNormalHeight{\customenvsiconsheigth}%
						\ifboolKV[customenvsicons]{educ}{\ceiconeduc[height=\customenvsIconsNormalHeight,#2]{#3}}{}%
						\ifboolKV[customenvsicons]{design}{\ceicondesign[height=\customenvsIconsNormalHeight,#2]{#3}}{}%
						\ifboolKV[customenvsicons]{mathsymb}{\ceiconmathsymb[height=\customenvsIconsNormalHeight,#2]{#3}}{}%
						\ifboolKV[customenvsicons]{game}{\ceicongame[height=\customenvsIconsNormalHeight,#2]{#3}}{}%
						\ifboolKV[customenvsicons]{bootstrap}{\ceiconbootstrap[height=\customenvsIconsNormalHeight,#2]{#3}}{}%
						\ifboolKV[customenvsicons]{solar}{\ceiconssolarbroken[height=\customenvsIconsNormalHeight,#2]{#3}}{}%
					}%
			}%
	}%
}

%====AI BADGE [FR]
\defKV[customenvsiconsia]{haut=\def\customenvsiconsheigth{#1},style=\def\customenvsiconsstyle{#1},strut=\def\customenvsiconsstrut{#1},dstrut=\def\customenvsiconsdstrut{#1}}
\setKVdefault[customenvsiconsia]{haut=dauto,style=rect,strut={X},dstrut={qX}}

\NewDocumentCommand\ceiconbadgeia{O{}D<>{}m}{%
	\restoreKV[customenvsiconsia]%
	\setKV[customenvsiconsia]{#1}%
	%offset page
	\IfStrEqCase{#3}{%
		{0}{\def\customenvsiconspageoffset{0}}%
		{20}{\def\customenvsiconspageoffset{1}}%
		{40}{\def\customenvsiconspageoffset{2}}%
		{60}{\def\customenvsiconspageoffset{3}}%
		{80}{\def\customenvsiconspageoffset{4}}%
		{100}{\def\customenvsiconspageoffset{5}}%
	}%
	%lengths
	\ifthenelse{\equal{\customenvsiconsheigth}{auto}}%
	{%
		\settoheight\customenvsIconsDefaultHeight{\hbox{\customenvsiconsstrut}}%height of \customenvsiconsstrut
		\ifthenelse{\equal{\customenvsiconsstyle}{rect}}{\includegraphics[height=\customenvsIconsDefaultHeight,#2,page=\numexpr1+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}{}%
		\ifthenelse{\equal{\customenvsiconsstyle}{carre}}{\includegraphics[height=\customenvsIconsDefaultHeight,#2,page=\numexpr7+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}{}%
		\ifthenelse{\equal{\customenvsiconsstyle}{ligne}}{\includegraphics[height=\customenvsIconsDefaultHeight,#2,page=\numexpr13+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}{}%
	}%
	{%
		\ifthenelse{\equal{\customenvsiconsheigth}{dauto}}%
			{%
				\settototalheight\customenvsIconsDefaultTotalHeight{\hbox{\customenvsiconsdstrut}}%height of \customenvsiconsdstrut
				\settodepth\customenvsIconsDefaultDepth{\hbox{\customenvsiconsdstrut}}%depth of \customenvsiconsdstrut
				\ifthenelse{\equal{\customenvsiconsstyle}{rect}}{\raisebox{-\customenvsIconsDefaultDepth}{\includegraphics[height=\customenvsIconsDefaultTotalHeight,#2,page=\numexpr1+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}}{}%
				\ifthenelse{\equal{\customenvsiconsstyle}{carre}}{\raisebox{-\customenvsIconsDefaultDepth}{\includegraphics[height=\customenvsIconsDefaultTotalHeight,#2,page=\numexpr7+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}}{}%
				\ifthenelse{\equal{\customenvsiconsstyle}{ligne}}{\raisebox{-\customenvsIconsDefaultDepth}{\includegraphics[height=\customenvsIconsDefaultTotalHeight,#2,page=\numexpr13+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}}{}%
			}%
			{%
				\IfSubStr{\customenvsiconsheigth}{/}%
					{%
						\StrCut{\customenvsiconsheigth}{/}{\ceiconsmanualheight}{\ceiconsmanualdepth}%
						\setlength\customenvsIconsNormalHeight{\ceiconsmanualheight}%
						\setlength\customenvsIconsDefaultDepth{\ceiconsmanualdepth}%
						\ifthenelse{\equal{\customenvsiconsstyle}{rect}}{\raisebox{\customenvsIconsDefaultDepth}{\includegraphics[height=\customenvsIconsNormalHeight,#2,page=\numexpr1+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}}{}%
						\ifthenelse{\equal{\customenvsiconsstyle}{carre}}{\raisebox{\customenvsIconsDefaultDepth}{\includegraphics[height=\customenvsIconsNormalHeight,#2,page=\numexpr7+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}}{}%
						\ifthenelse{\equal{\customenvsiconsstyle}{ligne}}{\raisebox{\customenvsIconsDefaultDepth}{\includegraphics[height=\customenvsIconsNormalHeight,#2,page=\numexpr13+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}}{}%
					}%
					{%
						\setlength\customenvsIconsNormalHeight{\customenvsiconsheigth}%
						\ifthenelse{\equal{\customenvsiconsstyle}{rect}}{\includegraphics[height=\customenvsIconsNormalHeight,#2,page=\numexpr1+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}{}%
						\ifthenelse{\equal{\customenvsiconsstyle}{carre}}{\includegraphics[height=\customenvsIconsNormalHeight,#2,page=\numexpr7+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}{}%
						\ifthenelse{\equal{\customenvsiconsstyle}{ligne}}{\includegraphics[height=\customenvsIconsNormalHeight,#2,page=\numexpr13+\customenvsiconspageoffset\relax]{ce-badgeai-all.pdf}}{}%
					}%
			}%
	}%
}

