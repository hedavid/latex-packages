			}%
			{%
				\fill[colorprogressbartikz] (0,0) rectangle ({#1},1);
			}%
		\draw[colorprogressbarbordertikz] (0,0) rectangle (1,1);
	\end{tikzpicture}%
}

\defKV[progressbartikz]{%
