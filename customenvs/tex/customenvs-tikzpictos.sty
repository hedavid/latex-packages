\newcommand\intprogressbartikz[1]{%
	\begin{tikzpicture}[x={\widthprogressbartikz},y={\heightprogressbartikz},line width={\fpeval{0.0375*\heightprogressbartikz}pt},scale=\fpeval{1/(1+0.0375)}]
		\ifboolKV[progressbartikz]{shade}
