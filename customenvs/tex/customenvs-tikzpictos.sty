	}%
	\xdef\tkzpoolballscale{\fpeval{\tkzpoolballheight/20.2mm}}%
	%picture
	\intpictotestdautolen{#3}%
	{%
		\setlength\tkzpoolballdepth{\dimexpr-\tkzpoolballdepth+\fpeval{(1-\tkzpoolballrescale)/2}\tkzpoolballheight\relax}%
		\raisebox{\tkzpoolballdepth}{%
			\begin{tikzpicture}[scale=\tkzpoolballscale,transform shape]
