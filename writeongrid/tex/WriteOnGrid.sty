	Couleur=\def\SeyesParCouleur{#1},%
	Echelle=\def\SeyesParEchelle{#1},%
	Espacement=\def\SeyesParBase{#1},%
	Ligne=\def\SeyesPar{#1},%
	Largeur=\def\SeyesParLarg{#1}
}
