\PYG{k}{\PYGZbs{}end}\PYG{n+nb}{\PYGZob{}}EnvGrid\PYG{n+nb}{\PYGZcb{}}

\PYG{c}{\PYGZpc{}12x3 lines \PYGZdq{}Ruled\PYGZdq{}, w/o overtakins, Ruled colors, centered, with 2\PYGZhy{}margin}
