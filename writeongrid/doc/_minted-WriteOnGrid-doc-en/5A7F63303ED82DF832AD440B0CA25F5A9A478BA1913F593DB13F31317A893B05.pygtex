\begin{Verbatim}[commandchars=\\\{\}]
\PYG{c}{\PYGZpc{}18x4 big squares, w/o overtaking, Seyes colors, 3\PYGZhy{}margin}
\PYG{k}{\PYGZbs{}begin}\PYG{n+nb}{\PYGZob{}}EnvGrid\PYG{n+nb}{\PYGZcb{}}[NumSquares=18x4,Grid=Seyes,Margin=3]\PYGZlt{}\PYG{k}{\PYGZbs{}ColSeyes}\PYGZgt{}
\PYG{k}{\PYGZbs{}end}\PYG{n+nb}{\PYGZob{}}EnvGrid\PYG{n+nb}{\PYGZcb{}}

\PYG{c}{\PYGZpc{}36x8 small squares, overtakings 3/3, PapierGris color}
