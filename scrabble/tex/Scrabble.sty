% ----- Commandes pour placer des mots -----
% / Befehle zum Platzieren von Wörtern
\newcommand\ScrabblePlaceMot[3][H]{%
  \IfStrEq{#1}{H}%
    {\path (#3) pic {placemotH={#2}};}%
    {\path (#3) pic {placemotV={#2}};}%
}
\newcommand\ScrabblePutWord[3][H]{%
  \IfStrEq{#1}{H}%
    {\path (#3) pic {placemotH={#2}};}%
    {\path (#3) pic {placemotV={#2}};}%
}

