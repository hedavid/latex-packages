% ----- Calcul des points pour une lettre (incluant *IN et SS) -----
% Fonction pour récupérer le score d'une lettre, avec gestion du joker (*) et des jetons spéciaux (*IN, SS)
% / Funktion zur Punkteberechnung für einen Buchstaben, mit Joker (*) und Sondersteinen (*IN, SS)
\newcommand\scrabblescorelettre[2][EN]{%
  \IfStrEq{#2}{*}{% Joker
    {}%
  }{%
    \IfSubStr{\AlphabetMajuscule}{#2}{% Majuscule ou minuscule
      \StrPosition{\AlphabetMajuscule}{#2}[\pos]% Position dans l'alphabet (majuscule)
    }{%
      \StrPosition{\AlphabetMinuscule}{#2}[\pos]% Position dans l'alphabet (minuscule)
    }%
    \IfStrEq{#1}{FR}{\PtsScrbFR[\pos]}{}% Score FR
    \IfStrEq{#1}{EN}{\PtsScrbEN[\pos]}{}% Score EN
    \IfStrEq{#1}{DE}{\PtsScrbDE[\pos]}{}% Score DE
    \IfStrEq{#1}{ES}{\PtsScrbES[\pos]}{}% Score ES
  }%
}

% ----- Libellés localisés (adaptés pour l'allemand) -----
% Libellés raccourcis pour l'allemand, conformes à l'usage officiel du Scrabble en Allemagne
% / Kürzere deutsche Beschriftungen, entsprechend der offiziellen Scrabble-Regeln in Deutschland
\newcommand\SCRBMCT[1]{%
  \IfStrEq{#1}{DE}{DREIFACH\\[-0.3ex]WORT}{}% DREIFACH WORT (3x Wortwert)
  \IfStrEq{#1}{FR}{MOT\\[-0.3ex]COMPTE\\[-0.3ex]TRIPLE}{}
  \IfStrEq{#1}{EN}{TRIPLE\\[-0.3ex]WORD\\[-0.3ex]SCORE}{}
  \IfStrEq{#1}{ES}{TRIPLE\\[-0.3ex]PALABRA}{}
}
\newcommand\SCRBMCD[1]{%
  \IfStrEq{#1}{DE}{DOPPELT\\[-0.3ex]WORT}{}% DOPPELT WORT (2x Wortwert)
  \IfStrEq{#1}{FR}{MOT\\[-0.3ex]COMPTE\\[-0.3ex]DOUBLE}{}
  \IfStrEq{#1}{EN}{DOUBLE\\[-0.3ex]WORD\\[-0.3ex]SCORE}{}
  \IfStrEq{#1}{ES}{DOBLE\\[-0.3ex]PALABRA}{}
}
\newcommand\SCRBLCT[1]{%
  \IfStrEq{#1}{DE}{DREIFACH\\[-0.3ex]BUCHSTABE}{}% DREIFACH BUCHSTABE (3x Buchstabenwert)
  \IfStrEq{#1}{FR}{LETTRE\\[-0.3ex]COMPTE\\[-0.3ex]TRIPLE}{}
  \IfStrEq{#1}{EN}{TRIPLE\\[-0.3ex]LETTER\\[-0.3ex]SCORE}{}
  \IfStrEq{#1}{ES}{TRIPLE\\[-0.3ex]LETRA}{}
}
\newcommand\SCRBLCD[1]{%
  \IfStrEq{#1}{DE}{DOPPELT\\[-0.3ex]BUCHSTABE}{}% DOPPELT BUCHSTABE (2x Buchstabenwert)
  \IfStrEq{#1}{FR}{LETTRE\\[-0.3ex]COMPTE\\[-0.3ex]DOUBLE}{}
  \IfStrEq{#1}{EN}{DOUBLE\\[-0.3ex]LETTER\\[-0.3ex]SCORE}{}
  \IfStrEq{#1}{ES}{DOBLE\\[-0.3ex]LETRA}{}
}

% ----- Couleurs allemandes pour le plateau et les jetons -----
% Couleurs inspirées du Scrabble allemand officiel (Mattel)
% / Farben inspiriert vom offiziellen deutschen Scrabble (Mattel)
\colorlet{triplewordscore}{red!80!black}       % DREIFACH WORT (rot foncé)
\colorlet{doublewordscore}{red!50}            % DOPPELT WORT (rot clair)
\colorlet{tripleletterscore}{blue!80}        % DREIFACH BUCHSTABE (bleu foncé)
\colorlet{doubleletterscore}{blue!50}        % DOPPELT BUCHSTABE (bleu clair)
\colorlet{scrabblebgtile}{yellow!30}          % Fond des jetons (jaune pâle)
\colorlet{scrabblebloard}{brown!20}          % Fond du plateau (marron clair)

% ----- Styles TikZ pour les jetons et les cases -----
\tikzset{
  scorelettre/.style={
    font=\sffamily\bfseries\tiny,align=center,draw=none,fill=none
  },
  pics/.cd,
  pointes/.style args={#1#2#3}{
    code={
      \fill [#3,scale=0.5*0.9] (-1,1) {
        \foreach \i in {0,1,2,3}{
          [rotate=-\i*90] -- (-#1*#2,1) {
            \foreach \j in {1,...,#1} {-- ++(#2,#2) -- ++(#2,-#2)}
          } -- (1,1)
        }
      } -- cycle;
    }
  },
  casecentrale/.style={
    code={
      \path pic {pointes={2}{0.15}{doublewordscore}};
      \node [scale=\fpeval{\PLSCRBBLEechelleLabel*0.9},star,fill,star point ratio=2.35] {};
    }
  },
  jeton/.style={
    code={
      % --- Jeton standard (lettres A-Z) ---
      % / Standard-Stein (Buchstaben A-Z)
      \IfStrEq{#1}{*}{% Joker
        \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {};
      }{%
        % --- Jetons spéciaux pour l'allemand ---
        % / Spezielle Steine für Deutsch
        \IfStrEq{#1}{Ä}{% Ä (6 points)
          \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {\"A};
          \node[inner sep=2pt,font=\sffamily\scriptsize,anchor=south east] at (JETON.south east) { \scrabblescorelettre[\PLSCRBBLElangue]{Ä} };
        }{%
          \IfStrEq{#1}{Ö}{% Ö (8 points)
            \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {\"O};
            \node[inner sep=2pt,font=\sffamily\scriptsize,anchor=south east] at (JETON.south east) { \scrabblescorelettre[\PLSCRBBLElangue]{Ö} };
          }{%
            \IfStrEq{#1}{Ü}{% Ü (8 points)
              \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {\"U};
              \node[inner sep=2pt,font=\sffamily\scriptsize,anchor=south east] at (JETON.south east) { \scrabblescorelettre[\PLSCRBBLElangue]{Ü} };
            }{%
              \IfStrEq{#1}{SS}{% SS (8 points) – Ligature allemande
                \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {\scalebox{0.7}[1]{SS}};
                \node[inner sep=2pt,font=\sffamily\scriptsize,anchor=south east] at (JETON.south east) { \scrabblescorelettre[\PLSCRBBLElangue]{SS} };
              }{%
                \IfStrEq{#1}{*IN}{% Genderstein (10 points) – Jeton de genre allemand
                  % Le Genderstein (*IN) est utilisé pour le genre en allemand.
                  % Règles: Uniquement à la fin des noms relatifs aux personnes (ex: LEHRER*IN).
                  % / Der Genderstein (*IN) wird zum Gendern im Deutschen verwendet.
                  % / Regeln: Nur am Ende von personenbezogenen Substantiven (z. B. LEHRER*IN).
                  \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {\scalebox{0.5}[1]{*IN}};
                  \node[inner sep=2pt,font=\sffamily\scriptsize,anchor=south east] at (JETON.south east) {10};
                }{%
                  % --- Jetons spéciaux pour d'autres langues (ES: CH, RR, LL, Ñ) ---
                  % / Spezielle Steine für andere Sprachen (ES: CH, RR, LL, Ñ)
                  \IfInteger{#1}{%
                    \IfEq{#1}{6}{% CH (Espagnol, 5 points)
                      \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {\scalebox{0.5}[1]{CH}};
                      \node[inner sep=2pt,font=\sffamily\scriptsize,anchor=south east] at (JETON.south east) { \scrabblescorelettre[\PLSCRBBLElangue]{#1} };
                    }{%
                      \IfEq{#1}{7}{% Ñ (Espagnol, 8 points)
                        \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {\~{N}};
                        \node[inner sep=2pt,font=\sffamily\scriptsize,anchor=south east] at (JETON.south east) { \scrabblescorelettre[\PLSCRBBLElangue]{#1} };
                      }{%
                        \IfEq{#1}{8}{% RR (Espagnol, 8 points)
                          \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {\scalebox{0.5}[1]{RR}};
                          \node[inner sep=2pt,font=\sffamily\scriptsize,anchor=south east] at (JETON.south east) { \scrabblescorelettre[\PLSCRBBLElangue]{#1} };
                        }{%
                          \IfEq{#1}{9}{% LL (Espagnol, 8 points)
                            \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {\scalebox{0.5}[1]{LL}};
                            \node[inner sep=2pt,font=\sffamily\scriptsize,anchor=south east] at (JETON.south east) { \scrabblescorelettre[\PLSCRBBLElangue]{#1} };
                          }{%
                            % Jeton standard (lettre simple)
                            \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {\expandafter\MakeUppercase\expandafter{#1}};
                            \node[inner sep=2pt,font=\sffamily\scriptsize,anchor=south east] at (JETON.south east) { \scrabblescorelettre[\PLSCRBBLElangue]{#1} };
                          }%
                        }%
                      }%
                    }%
                  }{%
                    % Jeton standard (lettre simple, ex: A, B, ...)
                    \node[fill=scrabblebgtile,minimum size=0.9 cm,rounded corners=\fpeval{\PLSCRBBLEechelle*0.15} cm,font=\Large\sffamily\bfseries] (JETON) {\expandafter\MakeUppercase\expandafter{#1}};
                    \node[inner sep=2pt,font=\sffamily\scriptsize,anchor=south east] at (JETON.south east) { \scrabblescorelettre[\PLSCRBBLElangue]{#1} };
                  }%
                }%
              }%
            }%
          }%
        }%
      }%
    }
  },
