 \RequirePackage{tikz}
 \usetikzlibrary{calc, shapes.geometric}
 \RequirePackage{xcolor}
 \RequirePackage{xstring}
 
 % --- Définitions des couleurs / Farbendefinitionen ---
 \definecolor{scrRed}{HTML}{E51A1C}       % Mot compte triple / Dreifacher Wortwert
 \definecolor{scrPink}{HTML}{F094A4}      % Mot compte double / Doppelter Wortwert
 \definecolor{scrDarkBlue}{HTML}{3581D8}  % Lettre compte triple / Dreifacher Buchstabenwert
 \definecolor{scrLightBlue}{HTML}{A9D1EA} % Lettre compte double / Doppelter Buchstabenwert
 \definecolor{scrBg}{HTML}{D1E3D1}        % Fond du plateau / Spielbrett Hintergrund (grünlich/vert)
 \definecolor{scrTile}{HTML}{FDF2D8}      % Couleur de la tuile / Steinfarbe
 
 % --- Coordonnées des cases spéciales / Felder-Koordinaten ---
 % X/Y, 0-14, (0,0) en haut à gauche / oben links
 \def\scrRedFields{0/0, 7/0, 14/0, 0/7, 14/7, 0/14, 7/14, 14/14}
 \def\scrPinkFields{1/1, 2/2, 3/3, 4/4, 10/10, 11/11, 12/12, 13/13, 1/13, 2/12, 3/11, 4/10, 10/4, 11/3, 12/2, 13/1, 7/7}
 \def\scrDarkBlueFields{5/1, 9/1, 1/5, 5/5, 9/5, 13/5, 1/9, 5/9, 9/9, 13/9, 5/13, 9/13}
 \def\scrLightBlueFields{3/0, 11/0, 6/2, 8/2, 0/3, 7/3, 14/3, 2/6, 6/6, 8/6, 12/6, 3/7, 11/7, 2/8, 6/8, 8/8, 12/8, 0/11, 7/11, 14/11, 6/12, 8/12, 3/14, 11/14}
 
 % --- Macros d'aide pour le texte / Hilfsmakros für Text ---
 % Standard (Englisch/International)
 \def\scrTextTW{TRIPLE\\WORD\\SCORE}
 \def\scrTextDW{DOUBLE\\WORD\\SCORE}
 \def\scrTextTL{TRIPLE\\LETTER\\SCORE}
 \def\scrTextDL{DOUBLE\\LETTER\\SCORE}
 
 % Deutsch
 \def\scrTextDWS{DREIFACHER\\WORTWERT}
 \def\scrTextZWS{DOPPELTER\\WORTWERT}
 \def\scrTextDBS{DREIFACHER\\BUCHSTABEN-\\WERT}
 \def\scrTextZBS{DOPPELTER\\BUCHSTABEN-\\WERT}
 
 % --- Valeurs des lettres / Werte der Buchstaben ---
 % Standard Scrabble Werte (Englisch)
 \newcommand{\ScrabbleValue}[1]{%
  \IfStrEqCase{#1}{%
   {A}{1}{B}{3}{C}{3}{D}{2}{E}{1}{F}{4}{G}{2}{H}{4}{I}{1}{J}{8}%
   {K}{5}{L}{1}{M}{3}{N}{1}{O}{1}{P}{3}{Q}{10}{R}{1}{S}{1}{T}{1}%
   {U}{1}{V}{4}{W}{4}{X}{8}{Y}{4}{Z}{10}%
  }[0]% Blanko-Stein (0 Punkte)
 }
 
 % Deutsche Scrabble Werte
 \newcommand{\ScrabbleValueDE}[1]{%
  \IfStrEqCase{#1}{%
   {A}{1}{B}{3}{C}{4}{D}{1}{E}{1}{F}{4}{G}{2}{H}{2}{I}{1}{J}{6}%
   {K}{4}{L}{2}{M}{3}{N}{1}{O}{2}{P}{4}{Q}{10}{R}{1}{S}{1}{T}{1}%
   {U}{1}{V}{6}{W}{3}{X}{8}{Y}{10}{Z}{3}{Ä}{6}{Ö}{8}{Ü}{6}%
   {*IN}{10}% Tuile de genre / Genderstein Sonderwert
  }[0]% Tuile blanche / Blanko-Stein (0 Punkte)
 }
 
 % --- Fonction pour vérifier si une case est de la même couleur / Funktion zur Überprüfung der gleichen Farbe ---
 \newcommand{\isSameColor}[4]{%
  % #1: x, #2: y, #3: color list, #4: result macro
  \gdef#4{0}%
  \foreach \cx/\cy in #3 {%
   \ifnum \cx=#1 \ifnum \cy=#2 \gdef#4{1} \breakforeach \fi \fi%
  }%
 }
 
 % --- Dessiner les indicateurs de bord / Randmarkierungen zeichnen ---
 \newcommand{\drawEdgeIndicators}[4]{%
  % #1: x, #2: y, #3: color name, #4: color list macro
  \pgfmathtruncatemacro{\x}{#1}
  \pgfmathtruncatemacro{\y}{#2}
  \pgfmathsetmacro{\ypos}{14-\y}
  
  % Top Rand (Nicht am äußeren Rand zeichnen / Pas sur le bord extérieur)
  \pgfmathtruncatemacro{\ytop}{\y-1}
  \ifnum\y>0
  \isSameColor{\x}{\ytop}{#4}{\isSame}
  \ifnum\isSame=0
  \draw[color=#3, line width=2.5pt] (\x+0.15, \ypos+1) -- (\x+0.3, \ypos+1) (\x+0.425, \ypos+1) -- (\x+0.575, \ypos+1) (\x+0.7, \ypos+1) -- (\x+0.85, \ypos+1);
  \fi
  \fi
  
  % Bottom Rand (Nicht am äußeren Rand zeichnen / Pas sur le bord extérieur)
  \pgfmathtruncatemacro{\ybottom}{\y+1}
  \ifnum\y<14
  \isSameColor{\x}{\ybottom}{#4}{\isSame}
  \ifnum\isSame=0
  \draw[color=#3, line width=2.5pt] (\x+0.15, \ypos) -- (\x+0.3, \ypos) (\x+0.425, \ypos) -- (\x+0.575, \ypos) (\x+0.7, \ypos) -- (\x+0.85, \ypos);
  \fi
  \fi
  
  % Left Rand (Nicht am äußeren Rand zeichnen / Pas sur le bord extérieur)
  \pgfmathtruncatemacro{\xleft}{\x-1}
  \ifnum\x>0
  \isSameColor{\xleft}{\y}{#4}{\isSame}
  \ifnum\isSame=0
  \draw[color=#3, line width=2.5pt] (\x, \ypos+0.15) -- (\x, \ypos+0.3) (\x, \ypos+0.425) -- (\x, \ypos+0.575) (\x, \ypos+0.7) -- (\x, \ypos+0.85);
  \fi
  \fi
  
  % Right Rand (Nicht am äußeren Rand zeichnen / Pas sur le bord extérieur)
  \pgfmathtruncatemacro{\xright}{\x+1}
  \ifnum\x<14
  \isSameColor{\xright}{\y}{#4}{\isSame}
  \ifnum\isSame=0
  \draw[color=#3, line width=2.5pt] (\x+1, \ypos+0.15) -- (\x+1, \ypos+0.3) (\x+1, \ypos+0.425) -- (\x+1, \ypos+0.575) (\x+1, \ypos+0.7) -- (\x+1, \ypos+0.85);
  \fi
  \fi
 }
 
 % --- Dessiner la base du plateau / Spielbrett Basis zeichnen ---
 % Standard Board (Englisch/International)
 \newcommand{\ScrabbleBoard}{%
  \fill[scrBg] (0,0) rectangle (15,15);
  
  \foreach \x/\y in \scrRedFields {
   \fill[scrRed] (\x, 14-\y) rectangle ++(1,1);
   \node[align=center, font=\sffamily\fontsize{3.5}{4}\selectfont\bfseries, text=black] at (\x+0.5, 14-\y+0.5) {\scrTextTW};
   \drawEdgeIndicators{\x}{\y}{scrRed}{\scrRedFields}
  }
  \foreach \x/\y in \scrPinkFields {
   \fill[scrPink] (\x, 14-\y) rectangle ++(1,1);
   \node[align=center, font=\sffamily\fontsize{3.5}{4}\selectfont\bfseries, text=black] at (\x+0.5, 14-\y+0.5) {\scrTextDW};
   \drawEdgeIndicators{\x}{\y}{scrPink}{\scrPinkFields}
  }
  \foreach \x/\y in \scrDarkBlueFields {
   \fill[scrDarkBlue] (\x, 14-\y) rectangle ++(1,1);
   \node[align=center, font=\sffamily\fontsize{3}{3.5}\selectfont\bfseries, text=white] at (\x+0.5, 14-\y+0.5) {\scrTextTL};
   \drawEdgeIndicators{\x}{\y}{scrDarkBlue}{\scrDarkBlueFields}
  }
  \foreach \x/\y in \scrLightBlueFields {
   \fill[scrLightBlue] (\x, 14-\y) rectangle ++(1,1);
   \node[align=center, font=\sffamily\fontsize{3}{3.5}\selectfont\bfseries, text=black] at (\x+0.5, 14-\y+0.5) {\scrTextDL};
   \drawEdgeIndicators{\x}{\y}{scrLightBlue}{\scrLightBlueFields}
  }
  
  \node[star, star points=5, star point ratio=2.25, fill=black, minimum size=0.6cm] at (7.5,7.5) {};
  \draw[thick, black!80] (0,0) grid (15,15);
 }
 
 % Deutsches Board
 \newcommand{\ScrabbleBoardDE}{%
  % Fond du jeu / Hintergrund
  \fill[scrBg] (0,0) rectangle (15,15);
  
  \foreach \x/\y in \scrRedFields {
   \fill[scrRed] (\x, 14-\y) rectangle ++(1,1);
   \node[align=center, font=\sffamily\fontsize{3.5}{4}\selectfont\bfseries, text=black] at (\x+0.5, 14-\y+0.5) {\scrTextDWS};
   \drawEdgeIndicators{\x}{\y}{scrRed}{\scrRedFields}
  }
  \foreach \x/\y in \scrPinkFields {
   \fill[scrPink] (\x, 14-\y) rectangle ++(1,1);
   \node[align=center, font=\sffamily\fontsize{3.5}{4}\selectfont\bfseries, text=black] at (\x+0.5, 14-\y+0.5) {\scrTextZWS};
   \drawEdgeIndicators{\x}{\y}{scrPink}{\scrPinkFields}
  }
  \foreach \x/\y in \scrDarkBlueFields {
   \fill[scrDarkBlue] (\x, 14-\y) rectangle ++(1,1);
   \node[align=center, font=\sffamily\fontsize{3}{3.5}\selectfont\bfseries, text=white] at (\x+0.5, 14-\y+0.5) {\scrTextDBS};
   \drawEdgeIndicators{\x}{\y}{scrDarkBlue}{\scrDarkBlueFields}
  }
  \foreach \x/\y in \scrLightBlueFields {
   \fill[scrLightBlue] (\x, 14-\y) rectangle ++(1,1);
   \node[align=center, font=\sffamily\fontsize{3}{3.5}\selectfont\bfseries, text=black] at (\x+0.5, 14-\y+0.5) {\scrTextZBS};
   \drawEdgeIndicators{\x}{\y}{scrLightBlue}{\scrLightBlueFields}
  }
  
  % Étoile centrale sur la case rose / Mittelstern auf dem pinken Zentrumsfeld
  \node[star, star points=5, star point ratio=2.25, fill=black, minimum size=0.6cm] at (7.5,7.5) {};
  
  % Lignes de la grille / Gitterlinien
  \draw[thick, black!80] (0,0) grid (15,15);
 }
 
 % --- Dessiner la tuile de base / Basis-Stein zeichnen ---
 % Standard Basis-Stein
 \newcommand{\ScrabbleSteinBase}[3]{%
  \StrDel{#3}{ }[\cleanletter]%
  \begin{scope}[shift={(#1, #2)}]
   \filldraw[fill=scrTile, draw=black!70, rounded corners=1.5pt, thick] (0.05, 0.05) rectangle (0.95, 0.95);
   \node[font=\sffamily\bfseries\Large] at (0.5, 0.5) {\cleanletter};
   \node[font=\sffamily\tiny, anchor=south east, inner sep=2pt] at (0.95, 0.05) {\ScrabbleValue{\cleanletter}};
  \end{scope}
 }
 
 % Deutscher Basis-Stein
 \newcommand{\ScrabbleSteinBaseDE}[3]{%
  % #1: x-offset (cm)
  % #2: y-offset (cm)
  % #3: Lettre / Buchstabe
  \StrDel{#3}{ }[\cleanletter]% Supprimer les espaces / Leerzeichen entfernen
  \begin{scope}[shift={(#1, #2)}]
   \filldraw[fill=scrTile, draw=black!70, rounded corners=1.5pt, thick] (0.05, 0.05) rectangle (0.95, 0.95);
   \IfStrEq{\cleanletter}{*IN}{%
    % Logo *IN: hochgestelltes Sternchen und IN in Normalgröße / Asterisk en exposant et IN normal
    \node[font=\sffamily\bfseries\Large] at (0.5, 0.5) {\raisebox{0.6ex}{\small *}IN};
    \node[font=\sffamily\tiny, anchor=south east, inner sep=2pt] at (0.95, 0.05) {\ScrabbleValueDE{\cleanletter}};
   }{%
    \node[font=\sffamily\bfseries\Large] at (0.5, 0.5) {\cleanletter};
    \node[font=\sffamily\tiny, anchor=south east, inner sep=2pt] at (0.95, 0.05) {\ScrabbleValueDE{\cleanletter}};
   }
  \end{scope}
 }
 
 % --- Placer une tuile sur le plateau / Stein auf dem Spielfeld platzieren ---
 % Standard Stein
 \newcommand{\ScrabbleStein}[3]{%
  \ScrabbleSteinBase{#1}{14-#2}{#3}%
 }
 
 % Deutscher Stein
 \newcommand{\ScrabbleSteinDE}[3]{%
  \ScrabbleSteinBaseDE{#1}{14-#2}{#3}%
 }
 
 % --- Placer un mot / Wort setzen ---
 % Standard Wort
 \newcommand{\ScrabbleWort}[4][H]{%
  \foreach \letter [count=\lettercnt] in {#4} {%
   \IfStrEq{#1}{H}{%
    \pgfmathtruncatemacro{\xpos}{#2 + \lettercnt - 1}%
    \pgfmathtruncatemacro{\ypos}{#3}%
   }{%
    \pgfmathtruncatemacro{\xpos}{#2}%
    \pgfmathtruncatemacro{\ypos}{#3 + \lettercnt - 1}%
   }%
   \ScrabbleStein{\xpos}{\ypos}{\letter}%
  }
 }
 
 % Deutsches Wort
 \newcommand{\ScrabbleWortDE}[4][H]{%
  \foreach \letter [count=\lettercnt] in {#4} {%
   \IfStrEq{#1}{H}{%
    \pgfmathtruncatemacro{\xpos}{#2 + \lettercnt - 1}%
    \pgfmathtruncatemacro{\ypos}{#3}%
   }{%
    \pgfmathtruncatemacro{\xpos}{#2}%
    \pgfmathtruncatemacro{\ypos}{#3 + \lettercnt - 1}%
   }%
   \ScrabbleSteinDE{\xpos}{\ypos}{\letter}%
  }
 }
 
 % --- Dessiner le chevalet / Wortbank zeichnen ---
 % Standard Bank
 \newcommand{\ScrabbleBank}[2][]{%
  \begin{scope}[#1]
   \filldraw[fill=brown!40, draw=black!80, rounded corners=2pt, thick] (-0.2, -0.2) rectangle (7.2, 1.2);
   \foreach \letter [count=\lettercnt] in {#2} {%
    \pgfmathtruncatemacro{\xpos}{\lettercnt - 1}%
    \ScrabbleSteinBase{\xpos}{0}{\letter}%
   }
  \end{scope}
 }
 
 % Deutsche Bank
 \newcommand{\ScrabbleBankDE}[2][]{%
  \begin{scope}[#1]
   \filldraw[fill=brown!40, draw=black!80, rounded corners=2pt, thick] (-0.2, -0.2) rectangle (7.2, 1.2);
   \foreach \letter [count=\lettercnt] in {#2} {%
    \pgfmathtruncatemacro{\xpos}{\lettercnt - 1}%
    \ScrabbleSteinBaseDE{\xpos}{0}{\letter}%
   }
  \end{scope}
 }
 
 % --- Environnement pour le plateau / Umgebung für das Scrabble Board ---
 % Standard Umgebung
 \newenvironment{EnvScrabble}[1][]{%
  \begin{tikzpicture}[x=1cm, y=1cm, #1]
   \ScrabbleBoard
  }{%
  \end{tikzpicture}
 }
 
 % Deutsche Umgebung
 \newenvironment{EnvScrabbleDE}[1][]{%
  \begin{tikzpicture}[x=1cm, y=1cm, #1]
   \ScrabbleBoardDE
  }{%
  \end{tikzpicture}
 }
 
