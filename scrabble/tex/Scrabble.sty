% / A-Z (26), Ä (27), Ö (28), Ü (29), SS (30), *IN (31)
\def\AlphabetMajuscule{ABCDEFGHIJKLMNOPQRSTUVWXYZÄÖÜSS*IN}
\def\AlphabetMinuscule{abcdefghijklmnopqrstuvwxyzäöüßss*in}
\setsepchar{,}%
