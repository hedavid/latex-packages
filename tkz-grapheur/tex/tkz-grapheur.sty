    }%
  \ifboolKV[GraphiqueTikzAxes]{Grille}%
    {%
      \ifboolKV[GraphiqueTikz]{Milli}%
        {%
          \draw[pflgrilles,xstep=\fpeval{0.1*\pflgrillex},ystep=\fpeval{0.1*\pflgrilley}] ({\pflxmin},{\pflymin}) grid ({\pflxmax},{\pflymax});
