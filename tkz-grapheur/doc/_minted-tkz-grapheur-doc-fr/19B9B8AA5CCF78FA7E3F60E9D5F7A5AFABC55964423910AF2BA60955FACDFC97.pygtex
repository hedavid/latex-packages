		\PYG{n+nb}{\PYGZob{}}pi/6,pi/4,pi/3,pi/2,2*pi/3,3*pi/4,5*pi/6,pi\PYG{n+nb}{\PYGZcb{}}
		\PYG{n+nb}{\PYGZob{}}0,sqrt(2)/2,1/2,sqrt(3)/2,1,\PYGZhy{}1,\PYGZhy{}sqrt(3)/2,\PYGZhy{}1/2,\PYGZhy{}sqrt(2)/2\PYG{n+nb}{\PYGZcb{}}
