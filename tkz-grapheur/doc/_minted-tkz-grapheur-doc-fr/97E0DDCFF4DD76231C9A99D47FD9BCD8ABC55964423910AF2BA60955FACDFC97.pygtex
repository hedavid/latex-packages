	\PYG{k}{\PYGZbs{}PlacerAntecedents}\PYG{n+na}{[Style=x,Couleurs=blue/green!50!black,Traits]}\PYG{n+nb}{\PYGZob{}}ajust\PYG{n+nb}{\PYGZcb{}\PYGZob{}}325\PYG{n+nb}{\PYGZcb{}}
