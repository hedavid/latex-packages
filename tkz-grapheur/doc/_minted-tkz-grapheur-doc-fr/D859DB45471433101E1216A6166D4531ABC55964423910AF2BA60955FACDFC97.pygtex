\begin{Verbatim}[commandchars=\\\{\}]
\PYG{c}{\PYGZpc{} Cardioïde  r = 1 + cos(theta)}
\PYG{k}{\PYGZbs{}begin}\PYG{n+nb}{\PYGZob{}}GraphiqueTikz\PYG{n+nb}{\PYGZcb{}}[Xmin=\PYGZhy{}1.5,Xmax=2.5,Ymin=\PYGZhy{}1.5,Ymax=1.5]
	\PYG{k}{\PYGZbs{}TracerAxesGrilles}\PYG{n+na}{[Elargir=2.5mm]}\PYG{n+nb}{\PYGZob{}\PYGZcb{}\PYGZob{}\PYGZcb{}} \PYG{c}{\PYGZpc{}grille cartésienne}
