\PYG{c}{\PYGZpc{} Lemniscate de Bernoulli  r² = cos(2theta)}
\PYG{k}{\PYGZbs{}begin}\PYG{n+nb}{\PYGZob{}}GraphiqueTikz\PYG{n+nb}{\PYGZcb{}}[Xmin=\PYGZhy{}1.5,Xmax=1.5,Ymin=\PYGZhy{}1.5,Ymax=1.5]
	\PYG{k}{\PYGZbs{}TracerAxesGrilles}\PYG{n+na}{[Elargir=2.5mm]}\PYG{n+nb}{\PYGZob{}\PYGZcb{}\PYGZob{}\PYGZcb{}} \PYG{c}{\PYGZpc{}grille cartésienne}
	\PYG{k}{\PYGZbs{}TracerCourbePol}\PYG{n+na}{[Couleur=violet,Debut=0,Fin=6.28]}\PYG{c}{\PYGZpc{}}
		\PYG{n+nb}{\PYGZob{}}sqrt(max(cos(2*theta),0))\PYG{n+nb}{\PYGZcb{}}
\PYG{k}{\PYGZbs{}end}\PYG{n+nb}{\PYGZob{}}GraphiqueTikz\PYG{n+nb}{\PYGZcb{}}
