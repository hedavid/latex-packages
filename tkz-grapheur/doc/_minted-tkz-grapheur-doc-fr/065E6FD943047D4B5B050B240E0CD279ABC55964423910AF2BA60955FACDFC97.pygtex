\begin{Verbatim}[commandchars=\\\{\}]
\PYG{c}{\PYGZpc{}déterminer l\PYGZsq{}intersection de deux objets préalablement définis via [name path]}
\PYG{k}{\PYGZbs{}findintersectionspgf}\PYG{n+na}{[base nom nœuds]}\PYG{n+nb}{\PYGZob{}}objet1\PYG{n+nb}{\PYGZcb{}\PYGZob{}}objet2\PYG{n+nb}{\PYGZcb{}}[macro nb total]

\PYG{c}{\PYGZpc{}extraction (globale, non limitée à l\PYGZsq{}environnement) et stockage de coordonnées}
