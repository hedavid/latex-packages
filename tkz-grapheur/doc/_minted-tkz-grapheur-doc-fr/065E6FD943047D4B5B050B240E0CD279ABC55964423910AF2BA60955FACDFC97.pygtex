\PYG{k}{\PYGZbs{}gextractynodepgf}\PYG{n+nb}{\PYGZob{}}nœud\PYG{n+nb}{\PYGZcb{}}[\PYG{k}{\PYGZbs{}myycoord}]
\PYG{k}{\PYGZbs{}gextractxynodepgf}\PYG{n+nb}{\PYGZob{}}nœud\PYG{n+nb}{\PYGZcb{}}[\PYG{k}{\PYGZbs{}myxcoord}][\PYG{k}{\PYGZbs{}myycoord}]

\PYG{c}{\PYGZpc{}domaine entre courbes}
