%====MACRO PLATEAU MATHADOR
\defKV[Mathador]{%
	rayon=\setlength\mathtexadorradius{#1},%
	epaisseur=\def\mathtexadortypethick{#1}
}

\setKVdefault[Mathador]{%
	rayon=5cm,%
	logo=true,%
	epaisseur=auto,%
	ombre=true,%
	impression=false,%
	pastels=false
}

\NewDocumentCommand\PlateauMathador{ O{} D<>{} m m }{%
	\restoreKV[Mathador]%
	\setKV[Mathador]{#1}%
	\ifthenelse{\equal{\mathtexadortypethick}{auto}}%
		{\setlength\mathtexadorthick{0.005\mathtexadorradius}}%
		{\setlength\mathtexadorthick{\mathtexadortypethick}}%
	\setlength\mathtexadorradiusB{0.6143\mathtexadorradius}%
	\setlength\mathtexadorradiusC{0.4571\mathtexadorradius}%
