%====lengths
\newlength{\vscodeiconsDefaultTotalHeight}
\newlength{\vscodeiconsDefaultHeight}
\newlength{\vscodeiconsNormalHeight}
\newlength{\vscodeiconsDefaultDepth}
\AtBeginDocument{%
	\setlength{\vscodeiconsDefaultHeight}{\fontcharht\font`X}%
	\setlength{\vscodeiconsNormalHeight}{\fontcharht\font`X}%
	}

%====suppress warnings
\begingroup\expandafter\expandafter\expandafter\endgroup
\expandafter\ifx\csname pdfsuppresswarningpagegroup\endcsname\relax
\else
	\pdfsuppresswarningpagegroup=1\relax
\fi

%====macro for generating default version
\newcommand{\GenerateVscodeIconDefault}[2]{%
	\expandafter\newcommand\csname vscodeicondefault #2\endcsname[1]{%
		\includegraphics[page=#1, ##1]{vscodeicons-default-all.pdf}}%
}%

%====macro for generating filetype version
\newcommand{\GenerateVscodeIconFileType}[2]{%
	\expandafter\newcommand\csname vscodeiconfiletype #2\endcsname[1]{%
		\includegraphics[page=#1, ##1]{vscodeicons-filetype-all.pdf}}%
}%

%====macro for generating foldertype version
\newcommand{\GenerateVscodeIconFolderType}[2]{%
	\expandafter\newcommand\csname vscodeiconfoldertype #2\endcsname[1]{%
		\includegraphics[page=#1, ##1]{vscodeicons-foldertype-all.pdf}}%
}%

%====int macros
\newcommand{\vscodeicondefault}[2][height=\vscodeiconsDefaultHeight]{%
	\csname vscodeicondefault #2\endcsname{#1}%
}%

\newcommand{\vscodeiconfiletype}[2][height=\vscodeiconsDefaultHeight]{%
	\csname vscodeiconfiletype #2\endcsname{#1}%
}%

\newcommand{\vscodeiconfoldertype}[2][height=\vscodeiconsDefaultHeight]{%
	\csname vscodeiconfoldertype #2\endcsname{#1}%
}%

%====main macro
\defKV[vscodeicon]{height=\def\vscodeiconheigth{#1},strut=\def\vscodeiconstrut{#1},dstrut=\def\vscodeicondstrut{#1}}

\setKVdefault[vscodeicon]{height=dauto,default=true,filetype=false,foldertype=false,strut={X},dstrut={qX}}

\NewDocumentCommand\vscodeicon{O{}D<>{}m}{%
	\restoreKV[vscodeicon]%
	\setKV[vscodeicon]{#1}%
	%boolean
	\ifboolKV[vscodeicon]{filetype}{\setKV[vscodeicon]{default=false,foldertype=false}}{}%
	\ifboolKV[vscodeicon]{foldertype}{\setKV[vscodeicon]{default=false,filetype=false}}{}%
	%lengths
	\ifthenelse{\equal{\vscodeiconheigth}{auto}}%
		{%
			\settoheight\vscodeiconsDefaultHeight{\hbox{\vscodeiconstrut}}%height of \vscodeiconstrut
			\ifboolKV[vscodeicon]{default}%
				{%
					\vscodeicondefault[height=\vscodeiconsDefaultHeight,#2]{#3}%
				}%
				{}%
			\ifboolKV[vscodeicon]{filetype}%
				{%
					\vscodeiconfiletype[height=\vscodeiconsDefaultHeight,#2]{#3}%
				}%
				{}%
			\ifboolKV[vscodeicon]{foldertype}%
				{%
					\vscodeiconfoldertype[height=\vscodeiconsDefaultHeight,#2]{#3}%
				}%
				{}%
		}%
		{%
			\ifthenelse{\equal{\vscodeiconheigth}{dauto}}%
				{%
					\settototalheight\vscodeiconsDefaultTotalHeight{\hbox{\vscodeicondstrut}}%height of \vscodeicondstrut
					\settodepth\vscodeiconsDefaultDepth{\hbox{\vscodeicondstrut}}%depth of \vscodeicondstrut
					\ifboolKV[vscodeicon]{default}%
						{%
							\raisebox{-\vscodeiconsDefaultDepth}{%
								\vscodeicondefault[height=\vscodeiconsDefaultTotalHeight,#2]{#3}%
							}%
						}%
						{}%
					\ifboolKV[vscodeicon]{filetype}%
						{%
							\raisebox{-\vscodeiconsDefaultDepth}{%
								\vscodeiconfiletype[height=\vscodeiconsDefaultTotalHeight,#2]{#3}%
							}%
						}%
						{}%
					\ifboolKV[vscodeicon]{foldertype}%
						{%
							\raisebox{-\vscodeiconsDefaultDepth}{%
								\vscodeiconfoldertype[height=\vscodeiconsDefaultTotalHeight,#2]{#3}%
							}%
						}%
						{}%
				}%
				{%
					\IfSubStr{\vscodeiconheigth}{/}%
						{%
							\StrCut*{\vscodeiconheigth}{/}{\vscodeiconmanualheight}{\vscodeiconmanualdepth}%
							\setlength\vscodeiconsNormalHeight{\vscodeiconmanualheight}%
							\setlength\vscodeiconsDefaultDepth{\vscodeiconmanualdepth}%
							\ifboolKV[vscodeicon]{default}%
								{%
									\raisebox{\vscodeiconsDefaultDepth}{%
										\vscodeicondefault[height=\vscodeiconsNormalHeight,#2]{#3}%
									}%
								}%
								{}%
							\ifboolKV[vscodeicon]{filetype}%
								{%
									\raisebox{\vscodeiconsDefaultDepth}{%
										\vscodeiconfiletype[height=\vscodeiconsNormalHeight,#2]{#3}%
									}%
								}%
								{}%
							\ifboolKV[vscodeicon]{foldertype}%
								{%
									\raisebox{\vscodeiconsDefaultDepth}{%
										\vscodeiconfoldertype[height=\vscodeiconsNormalHeight,#2]{#3}%
									}%
								}%
								{}%
						}%
						{%
							\setlength\vscodeiconsNormalHeight{\vscodeiconheigth}%
							\ifboolKV[vscodeicon]{default}%
								{%
									\vscodeicondefault[height=\vscodeiconsNormalHeight,#2]{#3}%
								}%
								{}%
							\ifboolKV[vscodeicon]{filetype}%
								{%
									\vscodeiconfiletype[height=\vscodeiconsNormalHeight,#2]{#3}%
								}%
								{}%
							\ifboolKV[vscodeicon]{foldertype}%
								{%
									\vscodeiconfoldertype[height=\vscodeiconsNormalHeight,#2]{#3}%
								}%
								{}%
						}%
				}%
		}%
}

