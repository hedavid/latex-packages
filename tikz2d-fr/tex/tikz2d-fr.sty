%------Points
%%------Commandes internes pour les nœuds et points
\NewDocumentCommand\TransfPosTikzDD{ m }{%défaut below
	\def\PosTmpLabel{below}
	\IfEq{#1}{b}{\def\PosTmpLabel{below}}{}
	\IfEq{#1}{d}{\def\PosTmpLabel{right}}{}
	\IfEq{#1}{h}{\def\PosTmpLabel{above}}{}
	\IfEq{#1}{g}{\def\PosTmpLabel{left}}{}
	\IfEq{#1}{bg}{\def\PosTmpLabel{below left}}{}
	\IfEq{#1}{bd}{\def\PosTmpLabel{below right}}{}
	\IfEq{#1}{hg}{\def\PosTmpLabel{above left}}{}
	\IfEq{#1}{hd}{\def\PosTmpLabel{above right}}{}
}
\tikzset{pics/croixdd/.style args={#1/#2}{
		code={
			\draw[line width={0.4*#1},rotate=#2] (-#1,0) -- (#1,0);
			\draw[line width={0.4*#1},rotate=#2] (0,-#1) -- (0, #1);
		}
	},
	pics/croixdd/.default={4pt/0}
}

%%------Créer/Placer/Nommer Point(s) 2d
\defKV[TkzTwoDimPoint]{%
	PosLabel=\def\TwoDimLabel{#1},%
	DecalLabel=\def\TwoDimDecalLabel{#1},%
	StyleMarque=\def\TwoDimStylePt{#1},%
	TailleMarque=\def\TwoDimtaillePt{#1},%
	Couleur=\def\TwoDimCoul{#1},%
	TaillePolice=\def\TwoDimFonte{#1}
}

\setKVdefault[TkzTwoDimPoint]{%
	PosLabel={b},%
	DecalLabel=2pt,%
	StyleMarque=o,%
	TailleMarque=2.5pt,%
	Couleur=black,%
	Math=false,%
	TaillePolice=\normalsize
}

\NewDocumentCommand\DefinirPoint{ s O{} m m D<>{#3} }{%
	%*=label
	%2=clés
	%3=nom nœud
	%4=coordonnées x,y
	%5=label si différent
	\useKVdefault[TkzTwoDimPoint]%
	\setKV[TkzTwoDimPoint]{#2}%
	\TransfPosTikzDD{\TwoDimLabel}
	\coordinate (#3) at (#4) ;
	\IfBooleanTF{#1}%on désactive le label avec (*)
		{}%
		{\draw (#3) node[\TwoDimCoul,\PosTmpLabel=\TwoDimDecalLabel,font=\TwoDimFonte] {\ifboolKV[TkzTwoDimPoint]{Math}{$#5$}{#5}} ;}%
}

\NewDocumentCommand\DefinirPoints{ s O{} m }{%
	%*=labels off
	%2=clés
	%3=liste nom/coordonnées/pos
	%\useKVdefault[TkzTwoDimPoint]%
	%\setKV[TkzTwoDimPoint]{#2}%
	\setsepchar[.]{ ./}%
	\readlist*\ListePtsPlan{#3}
	\xintifboolexpr{\ListePtsPlanlen == 1}%
		{%
			\IfBooleanTF{#1}%on désactive le label avec (*)
				{%
					\DefinirPoint*[#2]{\ListePtsPlan[1,1]}{\ListePtsPlan[1,2]}
				}%
					{%
					\DefinirPoint[#2,PosLabel={\ListePtsPlan[1,3]}]{\ListePtsPlan[1,1]}{\ListePtsPlan[1,2]}
				}%
		}%
		{%
			\foreach \i in {1,2,...,\ListePtsPlanlen}
				{%
					\IfBooleanTF{#1}%on désactive le label avec (*)
						{%
							\DefinirPoint*[#2]{\ListePtsPlan[\i,1]}{\ListePtsPlan[\i,2]}
						}%
						{%
							\DefinirPoint[#2,PosLabel={\ListePtsPlan[\i,3]}]{\ListePtsPlan[\i,1]}{\ListePtsPlan[\i,2]}
						}%
				}%
		}%
}

\NewDocumentCommand\MarquerPoint{ O{} m }{%
	%1=clés
	%2=nom nœud
	\useKVdefault[TkzTwoDimPoint]%
	\setKV[TkzTwoDimPoint]{#1}%
	\IfStrEq{\TwoDimStylePt}{o}%
		{\filldraw[\TwoDimCoul] (#2) circle[radius={\TwoDimtaillePt-0.5pt}] ;}{}%
	\IfStrEq{\TwoDimStylePt}{x}%
		{\draw[\TwoDimCoul] (#2) pic{croixdd=\TwoDimtaillePt/45} ;}{}%
	\IfStrEq{\TwoDimStylePt}{+}%
		{\draw[\TwoDimCoul] (#2) pic{croixdd=\TwoDimtaillePt/0} ;}{}%
}

\NewDocumentCommand\MarquerPoints{ O{} m }{%
	%1=clés
	%2=liste nom/coordonnées/pos
	%\useKVdefault[TkzTwoDimPoint]%
	%\setKV[TkzTwoDimPoint]{#1}%
	\foreach \i in {#2}
	{%
		\MarquerPoint[#1]{\i}
	}%
}

%------Tracer des segments
\defKV[TraceSegments]{%
	Cap=\xdef\TracSegCap{#1},%
	Join=\xdef\TracSegJoin{#1},%
	Couleurs=\xdef\TracSegCoul{#1}
}

\setKVdefault[TraceSegments]{%
	Cap=round,%
	Couleurs=black,%
	Cycle=false,%
	Join=miter,%
	Suite=false
}

\NewDocumentCommand\TracerSegments{ O{} D<>{thick} m }{%
	\useKVdefault[TraceSegments]%
	\setKV[TraceSegments]{#1}%
	\ifboolKV[TraceSegments]{Suite}%si on enchaîne les points A->B->C, sinon A/B A/C ...
		{%
			\setsepchar{ }%
			\readlist*\LPTSEGM{#3}%
			\IfSubStr{\TracSegCoul}{,}%si ',' := un par un, sinon enchaine
				{%
					\setsepchar{,}%
					\readlist*\LCSEGM{\TracSegCoul}%
					\ifboolKV[TraceSegments]{Cycle}%
						{%
							\foreach \i in {1,2,...,\inteval{\LPTSEGMlen-1}}%
								{%
									\draw[color={\LCSEGM[\i]},line cap={\TracSegCap},#2] (\LPTSEGM[\i]) -- (\LPTSEGM[\inteval{\i+1}]) ;
								}%
							\draw[color={\LCSEGM[-1]},line cap={\TracSegCap},#2] (\LPTSEGM[-1]) -- (\LPTSEGM[1]) ;
						}%
						{%
							\foreach \i in {1,2,...,\inteval{\LPTSEGMlen-1}}%
								{%
									\draw[color={\LCSEGM[\i]},line cap={\TracSegCap},#2] (\LPTSEGM[\i]) -- (\LPTSEGM[\inteval{\i+1}]) ;
								}%
						}%
				}%
				{%
					\StrSubstitute{#3}{ }{)--(}[\tmplstpts]%
					\xdef\tmplstptsconv{(\tmplstpts)}%
					\ifboolKV[TraceSegments]{Cycle}%
						{%
							\draw[color={\TracSegCoul},line join={\TracSegJoin},#2] \tmplstptsconv--cycle ;
						}%
						{%
							\draw[color={\TracSegCoul},line join={\TracSegJoin},#2] \tmplstptsconv ;
						}%
				}%
		}%
		{%
			\setsepchar[.]{ ./}%
			\readlist*\LPTSEGM{#3}%
			\IfSubStr{\TracSegCoul}{,}%si ',' := un par un, sinon enchaine
				{%
					\setsepchar{,}
					\readlist*\LCSEGM{\TracSegCoul}%
					\xintifboolexpr{\LPTSEGMlen == 1}%
						{%
							\draw[color={\LCSEGM[1]},line cap={\TracSegCap},#2] (\LPTSEGM[1,1]) -- (\LPTSEGM[1,2]) ;
						}%
						{%
							\foreach \i in {1,2,...,\LPTSEGMlen}%
								{%
									\draw[color={\LCSEGM[\i]},line cap={\TracSegCap},#2] (\LPTSEGM[\i,1]) -- (\LPTSEGM[\i,2]) ;
								}%
						}%
					
				}%
				{%
					\xintifboolexpr{\LPTSEGMlen == 1}%
						{%
							\draw[color={\TracSegCoul},line cap={\TracSegCap},#2] (\LPTSEGM[1,1]) -- (\LPTSEGM[1,2]) ;
						}%
						{%
							\foreach \i in {1,2,...,\LPTSEGMlen}%
							{%
								\draw[color={\TracSegCoul},line cap={\TracSegCap},#2] (\LPTSEGM[\i,1]) -- (\LPTSEGM[\i,2]) ;
							}%
						}%
				}%
		}%
}

%------Définir des points par transformations
\NewDocumentCommand\ImagePoint{ s O{} m D<>{\tmpptdef} }{%
	\useKVdefault[TkzTwoDimPoint]%
	\setKV[TkzTwoDimPoint]{#2}%
	%si c'est un translation
	\IfSubStr{#3}{t(}%
		{%
			\StrBefore{#3}{=}[\tmpptdef]%
			\StrBetween{#3}{=}{+}[\tmpptdeb]%
			\IfSubStr{#3}{,}%
				{%
					\StrBetween{#3}{t(}{,}[\tmpk]%
					\StrBetween{#3}{,}{>}[\tmpvecdeb]%
					\StrBetween{#3}{>}{)}[\tmpvecfin]%
				}%
				{%
					\xdef\tmpk{1}%
					\StrBetween{#3}{t(}{>}[\tmpvecdeb]%
				}%
			\StrBetween{#3}{>}{)}[\tmpvecfin]%
			\TransfPosTikzDD{\TwoDimLabel}%
			\coordinate (\tmpptdef) at ($(\tmpptdeb) + \tmpk*(\tmpvecfin) - \tmpk*(\tmpvecdeb)$) ;
		}{}%
	%si c'est une rotation
	\IfSubStr{#3}{r(}%
		{%
			\StrBefore{#3}{=}[\tmpptdef]%
			\StrBetween{#3}{=}{+}[\tmpptdeb]%
			\StrBetween{#3}{r(}{,}[\tmpptcenter]%
			\StrBetween{#3}{,}{)}[\tmpangle]%
			\TransfPosTikzDD{\TwoDimLabel}%
			\coordinate (\tmpptdef) at ([rotate around={\tmpangle:(\tmpptcenter)}]\tmpptdeb);
		}{}%
	%si c'est une symetrie
	\IfSubStr{#3}{s(}%
		{%
			\StrBefore{#3}{=}[\tmpptdef]%
			\StrBetween{#3}{=}{+}[\tmpptdeb]%
			\StrBetween{#3}{s(}{)}[\tmpptcenter]%
			\TransfPosTikzDD{\TwoDimLabel}%
			\coordinate (\tmpptdef) at ([rotate around={180:(\tmpptcenter)}]\tmpptdeb);
		}%
		{}%
	\IfBooleanTF{#1}%on désactive le label avec (*)
		{}%
		{\draw (\tmpptdef) node[\TwoDimCoul,\PosTmpLabel=\TwoDimDecalLabel,font=\TwoDimFonte] {\ifboolKV[TkzTwoDimPoint]{Math}{$#4$}{#4}} ;}%
}

\NewDocumentCommand\ImagesPoints{ s O{} m }{%
	\useKVdefault[TkzTwoDimPoint]%
	\setKV[TkzTwoDimPoint]{#2}%
	\setsepchar{§}%
	\readlist*\listetmptransf{#3}%
	\foreachitem \formule \in \listetmptransf{%
		\IfBooleanTF{#1}%
			{%
				\ImagePoint*[#2]{\formule}%
			}%
			{%
				\ImagePoint[#2]{\formule}%
			}%
	}%
}

%====Orthogone de Lill
\ExplSyntaxOn
	\NewDocumentCommand\ConvertirPtToUnit{ m } { \dim_to_decimal_in_unit:nn { #1 } { 1 cm } }
\ExplSyntaxOff

\defKV[OrthogLill]{%
	Echelle=\def\tmpLillEchelle{#1},%
	Arrondis=\def\tmpLillRound{#1}
}
\setKVdefault[OrthogLill]{%
	GrilleX=1,%
	GrilleY=1,%
	Echelle=1,%
	Coeffs=false,%
	Arrondis={}
}

\NewDocumentEnvironment{EnvOrthoLill}{ O{} m m m }
{%
	\restoreKV[OrthogLill]%
	\setKV[OrthogLill]{#1}%
	\def\tmpLillCoeffa{#2}%
	\def\tmpLillCoeffb{#3}%
	\def\tmpLillCoeffc{#4}%
	\IfStrEq{\tmpLillRound}{}%
		{%
			\xdef\PremSol{\xintfloateval{min((-(#3)-sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)),(-(#3)+sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)))}}%
			\xdef\DeuxSol{\xintfloateval{max((-(#3)-sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)),(-(#3)+sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)))}}%
		}%
		{%
			\xdef\PremSol{\xintfloateval{round(min((-(#3)-sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)),(-(#3)+sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2))),\tmpLillRound)}}%
			\xdef\DeuxSol{\xintfloateval{round(max((-(#3)-sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)),(-(#3)+sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2))),\tmpLillRound)}}%
		}%
	\xintifboolexpr{#2 > 0 }%
		{%
			\def\tmpLillCentreX{\xintfloateval{-(\tmpLillCoeffb)/2}}%
		}%
		{%
			\def\tmpLillCentreX{\xintfloateval{(\tmpLillCoeffb)/2}}%
		}%
	\def\tmpLillCentreY{\xintfloateval{(\tmpLillCoeffa-(\tmpLillCoeffc))/2}}%
	\def\tmpLillRayon{\xintfloateval{0.5*sqrt((\tmpLillCoeffb)^2+((\tmpLillCoeffa)-(\tmpLillCoeffc))^2)}}%
	\def\tmpLillMinX{\xintfloateval{min(\tmpLillCentreX-\tmpLillRayon,\PremSol,\DeuxSol)}}%
	\def\tmpLillMaxX{\xintfloateval{max(\tmpLillCentreX+\tmpLillRayon,\PremSol,\DeuxSol)}}%
	\def\tmpLillLargX{\xintfloateval{\tmpLillMaxX-\tmpLillMinX}}%
	\def\tmpLillMinY{\xintfloateval{\tmpLillCentreY-\tmpLillRayon}}%
	\def\tmpLillMaxY{\xintfloateval{max(\tmpLillCentreY+\tmpLillRayon,1)}}%
	\def\tmpLillLargY{\xintfloateval{\tmpLillMaxY-\tmpLillMinY}}%
	\begin{tikzpicture}[scale=\tmpLillEchelle]
		\begin{scope}
			\clip ({\tmpLillMinX-0.05*\tmpLillLargX},{\tmpLillMinY-0.05*\tmpLillLargY}) rectangle ({\tmpLillMaxX+0.05*\tmpLillLargX},{\tmpLillMaxY+0.05*\tmpLillLargY}) ;
			\draw[thin,lightgray,xstep={\useKV[OrthogLill]{GrilleX}},ystep={\useKV[OrthogLill]{GrilleY}}] ({\tmpLillMinX-0.05*\tmpLillLargX},{\tmpLillMinY-0.05*\tmpLillLargY}) grid ({\tmpLillMaxX+0.05*\tmpLillLargX},{\tmpLillMaxY+0.05*\tmpLillLargY}) ;
			\draw[thick] ({\tmpLillMinX-0.05*\tmpLillLargX},0) --({\tmpLillMaxX+0.05*\tmpLillLargX},0) ;
			\foreach \x in {0,{\useKV[OrthogLill]{GrilleX}},...,\tmpLillMaxX}{%
				\draw[thick] (\x,{2.25pt/\tmpLillEchelle})--++(0,{-4.5pt/\tmpLillEchelle}) ;
			}
			\foreach \x in {0,{-\useKV[OrthogLill]{GrilleX}},...,\tmpLillMinX}{%
				\draw[thick] (\x,{2.25pt/\tmpLillEchelle})--++(0,{-4.5pt/\tmpLillEchelle}) ;
			}
			\coordinate (A) at (0,0) ;
			\xintifboolexpr{#2 > 0}%
				{%
					\coordinate (B) at ($(A)+(90:{\tmpLillCoeffa})$) ;
					\coordinate (C) at ($(B)+(180:{\tmpLillCoeffb})$) ;
					\coordinate (D) at ($(C)+(270:{\tmpLillCoeffc})$) ;
				}%
				{%
					\coordinate (B) at ($(A)+(90:{\tmpLillCoeffa})$) ;
					\coordinate (C) at ($(B)+(180:{-\tmpLillCoeffb})$) ;
					\coordinate (D) at ($(C)+(270:{\tmpLillCoeffc})$) ;
				}%
			\tkzDefCircle[diameter](A,D)\tkzGetPoint{M}
			\xintifboolexpr{(#3)^2-4*(#2)*(#4) >= 0 }%
				{%si on a des solutions
					\tkzInterLC(B,C)(M,D)\tkzGetPoints{a}{b}
					\draw[red,thick,densely dotted] ({\tmpLillMinX-0.05*\tmpLillLargX},{#2})--({\tmpLillMaxX+0.05*\tmpLillLargX},{#2}) ;
					\tkzDrawSegments[thick,darkgray,densely dotted](a,D b,D)
					\tkzDrawSegments[thick,lightgray,densely dotted](A,D)
					\tkzDrawCircle[thick,blue,dashed](M,D)
					\tkzMarkRightAngle[thick,darkgray,size=\fpeval{0.25/\tmpLillEchelle}](A,a,D)
					\tkzMarkRightAngle[thick,darkgray,size=\fpeval{0.25/\tmpLillEchelle}](D,b,A)
				}%
				{}%
		\end{scope}
		%solutions
		\xintifboolexpr{(#3)^2-4*(#2)*(#4) >= 0 }%
			{%
				\xintifboolexpr{#2 > 0}%
					{%
						\coordinate (S1) at ({\PremSol},{1}) ;
						\coordinate (S2) at ({\DeuxSol},{1}) ;
						\draw[thick,orange,densely dashed] ({\tmpLillMinX-0.05*\tmpLillLargX},1)--({\tmpLillMaxX+0.05*\tmpLillLargX},1) ;
					}%
					{%
						\coordinate (S1) at ({\PremSol},{-1}) ;
						\coordinate (S2) at ({\DeuxSol},{-1}) ;
						\draw[thick,orange,densely dashed] ({\tmpLillMinX-0.05*\tmpLillLargX},-1)--({\tmpLillMaxX+0.05*\tmpLillLargX},-1) ;
					}%
				\xintifboolexpr{ abs(#2) < 1}%
					{%
						\tkzDrawSegments[thick,darkgray,densely dotted](A,S1 A,S2)
						
					}%
					{%
						\tkzDrawSegments[thick,darkgray,densely dotted](a,A b,A)
					}%
				\xintifboolexpr{#2 > 0}%
					{%
						\draw[thick,orange,->,>=latex] let \p1 = (S1) in (S1) -- ({\x1},0) node[below,font=\tiny] {$\PremSol$} ;
						\draw[thick,orange,->,>=latex] let \p1 = (S2) in (S2) -- ({\x1},0) node[below,font=\tiny] {$\DeuxSol$} ;
					}%
					{%
						\draw[thick,orange,->,>=latex] let \p1 = (S1) in (S1) -- ({\x1},0) node[above,font=\tiny] {$\PremSol$} ;
						\draw[thick,orange,->,>=latex] let \p1 = (S2) in (S2) -- ({\x1},0) node[above,font=\tiny] {$\DeuxSol$} ;
					}%
				\tkzDrawPoints(S1,S2)
			}%
			{}%
		\draw (A) node[below left,inner sep=1.25pt,font=\small,draw=none,fill=white] {0} ;
		\draw ({\useKV[OrthogLill]{GrilleX}},{-2.25pt/\tmpLillEchelle}) node[below,font=\footnotesize,inner sep=1.75pt,draw=none,fill=white] {\useKV[OrthogLill]{GrilleX}} ;
		\draw[red,thick,->,>=latex] (A)--(B)  \ifboolKV[OrthogLill]{Coeffs}{node[draw,semithick,font=\tiny,inner sep=1.75pt,fill=white,sloped,midway] {$\tmpLillCoeffa\vec{\jmath}$}}{} ;
		\draw[red,thick,->,>=latex] (B)--(C)  \ifboolKV[OrthogLill]{Coeffs}{node[draw,semithick,font=\tiny,inner sep=1.75pt,fill=white,sloped,midway] {$\xintifboolexpr{#2>0}{-(\tmpLillCoeffb)}{\tmpLillCoeffb}\vec{\imath}$}}{} ;
		\draw[red,thick,->,>=latex] (C)--(D)  \ifboolKV[OrthogLill]{Coeffs}{node[draw,semithick,font=\tiny,inner sep=1.75pt,fill=white,sloped,midway] {$-(\tmpLillCoeffc)\vec{\jmath}$}}{} ;
}%
{%
	\end{tikzpicture}%
}%

\NewDocumentCommand\OrthogoneLill{ O{} m m m }{%
	\restoreKV[OrthogLill]%
	\setKV[OrthogLill]{#1}%
	\def\tmpLillCoeffa{#2}%
	\def\tmpLillCoeffb{#3}%
	\def\tmpLillCoeffc{#4}%
	\xintifboolexpr{(#3)^2-4*(#2)*(#4) >= 0 'and' (#3)*(#4) != 0}%
		{%
			%extraction des solutions
			\IfStrEq{\tmpLillRound}{}%
				{%
					\xdef\PremSol{\xintfloateval{min((-(#3)-sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)),(-(#3)+sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)))}}%
					\xdef\DeuxSol{\xintfloateval{max((-(#3)-sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)),(-(#3)+sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)))}}%
				}%
				{%
					\xdef\PremSol{\xintfloateval{round(min((-(#3)-sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)),(-(#3)+sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2))),\tmpLillRound)}}%
					\xdef\DeuxSol{\xintfloateval{round(max((-(#3)-sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2)),(-(#3)+sqrt((#3)^2-4*(#2)*(#4)))/(2*(#2))),\tmpLillRound)}}%
				}%
			%le cas a<0
			\xintifboolexpr{#2 > 0 }%
				{%
