\defaultfontfeatures[Pennstander-Light]
{
  Extension           = .otf,
  UprightFont         = Pennstander-Light,
  ItalicFont          = Pennstander-ItalicLight,
  BoldFont            = Pennstander-Medium,
  BoldItalicFont      = Pennstander-ItalicMedium,
  SlantedFont         = Pennstander-Light,
  SlantedFeatures     = {FakeSlant=0.19},
  BoldSlantedFont     = Pennstander-Medium,
  BoldSlantedFeatures = {FakeSlant=0.19},
  Ligatures           = {Common,TeX}
}