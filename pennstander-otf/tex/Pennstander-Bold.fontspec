\defaultfontfeatures[Pennstander-Bold]
{
  Extension           = .otf,
  UprightFont         = Pennstander-Bold,
  ItalicFont          = Pennstander-ItalicBold,
  BoldFont            = Pennstander-Black,
  BoldItalicFont      = Pennstander-ItalicBlack,
  SlantedFont         = Pennstander-Bold,
  SlantedFeatures     = {FakeSlant=0.19},
  BoldSlantedFont     = Pennstander-Black,
  BoldSlantedFeatures = {FakeSlant=0.19},
  Ligatures           = {Common,TeX}
}