\defaultfontfeatures[Pennstander-Thin]
{
  Extension           = .otf,
  UprightFont         = Pennstander-Thin,
  ItalicFont          = Pennstander-ItalicThin,
  BoldFont            = Pennstander-Light,
  BoldItalicFont      = Pennstander-ItalicLight,
  SlantedFont         = Pennstander-Thin,
  SlantedFeatures     = {FakeSlant=0.19},
  BoldSlantedFont     = Pennstander-Light,
  BoldSlantedFeatures = {FakeSlant=0.19},
  Ligatures           = {Common,TeX}
}