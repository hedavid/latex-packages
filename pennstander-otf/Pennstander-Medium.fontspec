\defaultfontfeatures[Pennstander-Medium]
{
  Extension           = .otf,
  UprightFont         = Pennstander-Medium,
  ItalicFont          = Pennstander-ItalicMedium,
  BoldFont            = Pennstander-Bold,
  BoldItalicFont      = Pennstander-ItalicBold,
  SlantedFont         = Pennstander-Medium,
  SlantedFeatures     = {FakeSlant=0.19},
  BoldSlantedFont     = Pennstander-Bold,
  BoldSlantedFeatures = {FakeSlant=0.19},
  Ligatures           = {Common,TeX}
}