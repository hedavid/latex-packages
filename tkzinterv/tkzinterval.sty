\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{tkzinterval}[2025/10/10 Brackets, with tikz, v 1.0a]
%1.0a  Initial version

%====packages
\usepackage{tikz}
\usepackage{simplekv}

%====lengths
\AtBeginDocument{\settoheight\tkzintervfixedheight{\hbox{x}}}
\newlength\tkzintervfixedheight
\newlength\tkzintervvarheight
\newlength\tkzintervwidth
\newlength\tkzintervsep
\newlength\tkzintervhoriz

%====default values
\setlength\tkzintervhoriz{5pt}
\setlength\tkzintervwidth{0.9pt}
\def\tkzintervxoffset{0.75}
\def\tkzintervspacebefore{\,}
\def\tkzintervspaceafter{\,}

%====internal macro
\ExplSyntaxOn
\NewDocumentCommand{\inttkzintisin}{ m m m m }{
  \tl_set:Nx \l_tmpa_tl {#2}
  \str_if_in:NnTF { \l_tmpa_tl } {#1} {#3} {#4}
}
\ExplSyntaxOff

%====local keys
\defKV[tkzinterv]{%
  vsep=\setlength\tkzintervsep{#1},%
  overlap=\def\tkzintervoverlap{#1},%
  hsep=\def\tkzintervxoffset{#1},%
  space before=\def\tkzintervspacebefore{#1},%
  space after=\def\tkzintervspaceafter{#1}
}
\setKVdefault[tkzinterv]{%
  vsep=0.1em,%
  overlap=lr,%
  FF=true,OO=false,OF=false,FO=false,%
  hsep=0.75,%
  space before={\,},%
  space after={\,}
}

%====single bracket
\newcommand\inttkzintervlbracketo{%
  \draw[line width=\tkzintervscale\tkzintervwidth] ([xshift={-\fpeval{(1+\tkzintervxoffset)*\tkzintervscale}\tkzintervhoriz}]MYNODE.south west) -| ([xshift={-\fpeval{\tkzintervxoffset*\tkzintervscale}\tkzintervhoriz}]MYNODE.north west) --++ (-\tkzintervscale\tkzintervhoriz,0) ;
}

\newcommand\inttkzintervlbracketf{%
  \draw[line width=\tkzintervscale\tkzintervwidth] ([xshift={\fpeval{(1-\tkzintervxoffset)*\tkzintervscale}\tkzintervhoriz}]MYNODE.south west) -| ([xshift={-\fpeval{\tkzintervxoffset*\tkzintervscale}\tkzintervhoriz}]MYNODE.north west) --++ (\tkzintervscale\tkzintervhoriz,0) ;
}

\newcommand\inttkzintervrbracketo{%
  \draw[line width=\tkzintervscale\tkzintervwidth] ([xshift={\fpeval{(1+\tkzintervxoffset)*\tkzintervscale}\tkzintervhoriz}]MYNODE.south east) -| ([xshift={\fpeval{\tkzintervxoffset*\tkzintervscale}\tkzintervhoriz}]MYNODE.north east) --++ (\tkzintervscale\tkzintervhoriz,0) ;
}

\newcommand\inttkzintervrbracketf{%
  \draw[line width=\tkzintervscale\tkzintervwidth] ([xshift={\fpeval{(\tkzintervxoffset-1)*\tkzintervscale}\tkzintervhoriz}]MYNODE.south east) -| ([xshift={\fpeval{\tkzintervxoffset*\tkzintervscale}\tkzintervhoriz}]MYNODE.north east) --++ (-\tkzintervscale\tkzintervhoriz,0) ;
}

%====width style
\tikzset{tkzinterv main/.style={inner sep=0pt,outer xsep=0pt,outer ysep=\tkzintervsep}}

%====main mcro
\NewDocumentCommand\tkzinterval{O{}m}{%
  %keys & booleans
  \restoreKV[tkzinterv]%
  \setKV[tkzinterv]{#1}%
  \ifboolKV[tkzinterv]{OO}{\setKV[tkzinterv]{FF=false}}{}%
  \ifboolKV[tkzinterv]{FO}{\setKV[tkzinterv]{FF=false}}{}%
  \ifboolKV[tkzinterv]{OF}{\setKV[tkzinterv]{FF=false}}{}%
  %lengths
  \settoheight\tkzintervvarheight{\hbox{x}}%
  \xdef\tkzintervscale{\fpeval{\tkzintervvarheight/\tkzintervfixedheight}}%
  %before spacing
  \ifboolKV[tkzinterv]{FF}{\tkzintervspacebefore}{}%
  \ifboolKV[tkzinterv]{OO}{\inttkzintisin{l}{\tkzintervoverlap}{\kern-\fpeval{0.5*\tkzintervscale}\tkzintervhoriz\relax}{\tkzintervspacebefore}}{}%
  \ifboolKV[tkzinterv]{FO}{\tkzintervspacebefore}{}%
  \ifboolKV[tkzinterv]{OF}{\inttkzintisin{l}{\tkzintervoverlap}{\kern-\fpeval{0.5*\tkzintervscale}\tkzintervhoriz\relax}{\tkzintervspacebefore}}{}%
  %picture
  \begin{tikzpicture}[baseline=(MYNODE.base),line cap=butt]
    \node[tkzinterv main] (MYNODE) {\ensuremath{#2}} ;
    \ifboolKV[tkzinterv]{FF}{\inttkzintervlbracketf\inttkzintervrbracketf}{}%
    \ifboolKV[tkzinterv]{OO}{\inttkzintervlbracketo\inttkzintervrbracketo}{}%
    \ifboolKV[tkzinterv]{FO}{\inttkzintervlbracketf\inttkzintervrbracketo}{}%
    \ifboolKV[tkzinterv]{OF}{\inttkzintervlbracketo\inttkzintervrbracketf}{}%
  \end{tikzpicture}%
  %after spacing
  \ifboolKV[tkzinterv]{FF}{\tkzintervspaceafter}{}%
  \ifboolKV[tkzinterv]{OO}{\inttkzintisin{r}{\tkzintervoverlap}{\kern-\fpeval{0.5*\tkzintervscale}\tkzintervhoriz\relax}{\tkzintervspaceafter}}{}%
  \ifboolKV[tkzinterv]{FO}{\inttkzintisin{r}{\tkzintervoverlap}{\kern-\fpeval{0.5*\tkzintervscale}\tkzintervhoriz\relax}{\tkzintervspaceafter}}{}%
  \ifboolKV[tkzinterv]{OF}{\tkzintervspaceafter}{}%
}

\endinput